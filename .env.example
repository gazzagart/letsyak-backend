# LetsYak Server Configuration
# Copy to .env and fill in values, OR run ./setup.sh to auto-generate everything.
# NEVER commit .env — it contains secrets.

# ── Domains ───────────────────────────────────────────────────────────────────
# The Matrix homeserver domain (users will log in with @user:MATRIX_DOMAIN)
MATRIX_DOMAIN=chat.example.com

# TURN server domain — must NOT be behind Cloudflare proxy (grey cloud)
TURN_DOMAIN=turn.example.com

# Vault API and file storage domains
VAULT_API_DOMAIN=vault.example.com
VAULT_FILES_DOMAIN=files.example.com

# ── Server ────────────────────────────────────────────────────────────────────
PUBLIC_IP=1.2.3.4

# ── Secrets (auto-generated by setup.sh) ──────────────────────────────────────
POSTGRES_PASSWORD=
REGISTRATION_SECRET=
MACAROON_SECRET=
FORM_SECRET=
TURN_SECRET=

# ── MinIO Object Storage ──────────────────────────────────────────────────────
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
