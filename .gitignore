# =============================================================================
# Generated by setup.sh — never commit these
# =============================================================================

# Secrets and per-deployment config
.env

# Synapse (generated by setup.sh, contains passwords/keys)
synapse/homeserver.yaml
synapse/log.config
synapse/signing.key
synapse/media_store/

# Coturn (contains TURN secret)
coturn/turnserver.conf

# Well-known JSON (domain-specific, generated by setup.sh)
well-known/www/client.json
well-known/www/server.json

# Firebase push notification credentials — get from team password manager
sygnal/firebase-service-account.json

# Local dev Docker Compose override — each machine has its own
docker-compose.override.yml

